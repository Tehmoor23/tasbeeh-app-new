rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isIsoDate(v) {
      return v is string && v.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }

    function isScopedCollection(c, base) {
      return c == base
        || c == base + '_NUUR'
        || c == base + '_RO'
        || c == base + '_HO';
    }

    // external dynamic scopes, e.g. attendance_daily_ext_hamburg
    // app-normalized: ascii-safe [a-z0-9_-]+
    function isExternalScopedCollection(c, base) {
      return c.matches('^' + base + '_ext_[a-z0-9_\\-]+$');
    }

    function isNormalizedScopeKey(v) {
      return v is string && v.matches('^[a-z0-9_\\-]+$');
    }

    function isPrayerOverrideCollection(c) {
      return isScopedCollection(c, 'prayer_time_overrides')
        || isExternalScopedCollection(c, 'prayer_time_overrides');
    }

    function isAnnouncementCollection(c) {
      return isScopedCollection(c, 'prayer_announcements')
        || isExternalScopedCollection(c, 'prayer_announcements');
    }

    function isProgramConfigCollection(c) {
      return isScopedCollection(c, 'program_configs')
        || isExternalScopedCollection(c, 'program_configs');
    }

    function isRegistrationConfigCollection(c) {
      return isScopedCollection(c, 'registration_configs')
        || isExternalScopedCollection(c, 'registration_configs');
    }

    function isAttendanceDailyCollection(c) {
      return isScopedCollection(c, 'attendance_daily')
        || isExternalScopedCollection(c, 'attendance_daily');
    }

    function isProgramDailyCollection(c) {
      return isScopedCollection(c, 'attendance_program_daily')
        || isScopedCollection(c, 'attendance_programm_daily') // legacy typo collection
        || isExternalScopedCollection(c, 'attendance_program_daily')
        || isExternalScopedCollection(c, 'attendance_programm_daily');
    }

    function isRegistrationDailyCollection(c) {
      return isScopedCollection(c, 'attendance_registration_daily')
        || isExternalScopedCollection(c, 'attendance_registration_daily');
    }

    function isMemberEntriesCollection(c) {
      return isScopedCollection(c, 'attendance_member_entries')
        || isExternalScopedCollection(c, 'attendance_member_entries');
    }

    function isProgramEntriesCollection(c) {
      return isScopedCollection(c, 'attendance_program_entries')
        || isExternalScopedCollection(c, 'attendance_program_entries');
    }

    function isRegistrationEntriesCollection(c) {
      return isScopedCollection(c, 'attendance_registration_entries')
        || isExternalScopedCollection(c, 'attendance_registration_entries');
    }

    function isAllowedQrRegistrationDoc(deviceId) {
      return request.resource.data.keys().hasOnly([
        'browserDeviceId', 'idNumber', 'tanzeem', 'majlis', 'mosqueKey', 'externalScopeKey', 'updatedAt', 'createdAt'
      ])
      && request.resource.data.browserDeviceId == deviceId
      && request.resource.data.idNumber is string
      && request.resource.data.tanzeem is string
      && request.resource.data.majlis is string
      && request.resource.data.mosqueKey is string
      && request.resource.data.updatedAt is string
      && request.resource.data.createdAt is string
      // externalScopeKey optional for non-external mosques
      && (
        !('externalScopeKey' in request.resource.data)
        || request.resource.data.externalScopeKey is string
      )
      // hardening: external_guest registrations MUST carry a non-empty normalized scope
      && (
        request.resource.data.mosqueKey != 'external_guest'
        || (
          'externalScopeKey' in request.resource.data
          && isNormalizedScopeKey(request.resource.data.externalScopeKey)
          && request.resource.data.externalScopeKey.size() > 0
        )
      );
    }

    // prayer_time_overrides*
    match /{collection}/{docId} {
      allow read: if isPrayerOverrideCollection(collection)
                  && (docId == 'global' || docId == 'pending_next_day');

      allow create, update: if isPrayerOverrideCollection(collection)
                            && (docId == 'global' || docId == 'pending_next_day')
                            && request.resource.data.keys().hasOnly([
                              'enabled', 'soharAsrTime', 'maghribIshaaTime', 'manualTimes', 'updatedAt', 'dateISO'
                            ])
                            && (!('dateISO' in request.resource.data) || isIsoDate(request.resource.data.dateISO));

      // allow internal + external cleanup delete
      allow delete: if isPrayerOverrideCollection(collection)
                    && (docId == 'global' || docId == 'pending_next_day');
    }

    // prayer_announcements*
    match /{collection}/{docId} {
      allow read: if isAnnouncementCollection(collection) && docId == 'current';

      allow create, update: if isAnnouncementCollection(collection)
                            && docId == 'current'
                            && request.resource.data.keys().hasOnly(['text', 'updatedAt'])
                            && request.resource.data.text is string;

      // allow internal + external cleanup delete
      allow delete: if isAnnouncementCollection(collection) && docId == 'current';
    }

    // program_configs*
    match /{collection}/{docId} {
      allow read: if isProgramConfigCollection(collection);

      allow create, update: if isProgramConfigCollection(collection)
                            && isIsoDate(docId)
                            && request.resource.data.keys().hasOnly([
                              'name', 'title', 'subtitle', 'extraLine', 'startTime', 'updatedAt'
                            ])
                            && request.resource.data.name is string
                            && (!('title' in request.resource.data) || request.resource.data.title is string)
                            && (!('subtitle' in request.resource.data) || request.resource.data.subtitle is string)
                            && (!('extraLine' in request.resource.data) || request.resource.data.extraLine is string)
                            && request.resource.data.startTime is string;

      // allow internal + external cleanup delete
      allow delete: if isProgramConfigCollection(collection) && isIsoDate(docId);
    }

    // registration_configs*
    match /{collection}/{docId} {
      allow read: if isRegistrationConfigCollection(collection);

      allow create, update: if isRegistrationConfigCollection(collection)
                            && request.resource.data.keys().hasOnly([
                              'id', 'name', 'title', 'subtitle', 'extraLine', 'startDate', 'endDate', 'disabled', 'updatedAt',
                              'advanced', 'includeTanzeems', 'isPublic', 'onlyEhlVoters', 'allowDecline'
                            ])
                            && request.resource.data.name is string
                            && (!('title' in request.resource.data) || request.resource.data.title is string)
                            && (!('subtitle' in request.resource.data) || request.resource.data.subtitle is string)
                            && (!('extraLine' in request.resource.data) || request.resource.data.extraLine is string)
                            && request.resource.data.startDate is string
                            && request.resource.data.endDate is string
                            && request.resource.data.disabled is bool
                            && (!('allowDecline' in request.resource.data) || request.resource.data.allowDecline is bool);

      // allow internal + external cleanup delete
      allow delete: if isRegistrationConfigCollection(collection);
    }

    // attendance_daily*
    match /{collection}/{docId} {
      allow read: if isAttendanceDailyCollection(collection);
      allow create, update: if isAttendanceDailyCollection(collection) && isIsoDate(docId);

      // allow internal + external cleanup delete
      allow delete: if isAttendanceDailyCollection(collection) && isIsoDate(docId);
    }

    // attendance_program_daily* (+ attendance_programm_daily* legacy)
    match /{collection}/{docId} {
      allow read: if isProgramDailyCollection(collection);
      allow create, update: if isProgramDailyCollection(collection)
                            && docId.matches('^\\d{4}-\\d{2}-\\d{2}_.+$');

      // allow internal + external cleanup delete
      allow delete: if isProgramDailyCollection(collection)
                    && docId.matches('^\\d{4}-\\d{2}-\\d{2}_.+$');
    }

    // attendance_registration_daily*
    match /{collection}/{docId} {
      allow read: if isRegistrationDailyCollection(collection);
      allow create, update: if isRegistrationDailyCollection(collection);

      // allow internal + external cleanup delete
      allow delete: if isRegistrationDailyCollection(collection);
    }

    // attendance_member_entries*
    match /{collection}/{docId} {
      allow read: if isMemberEntriesCollection(collection);

      allow create, update: if isMemberEntriesCollection(collection)
                            && request.resource.data.keys().hasOnly([
                              'type', 'date', 'prayer', 'programName', 'majlis', 'tanzeem', 'idNumber', 'name', 'timestamp'
                            ])
                            && request.resource.data.type is string
                            && request.resource.data.date is string
                            && request.resource.data.tanzeem is string
                            && request.resource.data.majlis is string
                            && request.resource.data.idNumber is string
                            && request.resource.data.timestamp is string;

      // allow internal + external cleanup delete
      allow delete: if isMemberEntriesCollection(collection);
    }

    // attendance_program_entries*
    match /{collection}/{docId} {
      allow read: if isProgramEntriesCollection(collection);

      allow create, update: if isProgramEntriesCollection(collection)
                            && request.resource.data.keys().hasOnly([
                              'type', 'date', 'prayer', 'programName', 'majlis', 'tanzeem', 'idNumber', 'name', 'timestamp'
                            ])
                            && request.resource.data.type is string
                            && request.resource.data.date is string
                            && request.resource.data.tanzeem is string
                            && request.resource.data.majlis is string
                            && request.resource.data.idNumber is string
                            && request.resource.data.timestamp is string;

      // allow internal + external cleanup delete
      allow delete: if isProgramEntriesCollection(collection);
    }

    // attendance_registration_entries*
    match /{collection}/{docId} {
      allow read: if isRegistrationEntriesCollection(collection);

      allow create, update: if isRegistrationEntriesCollection(collection)
                            && request.resource.data.keys().hasOnly([
                              'type', 'date', 'registrationId', 'registrationName',
                              'majlis', 'tanzeem', 'idNumber', 'name', 'timestamp',
                              'registrationResponse', 'declineReason'
                            ])
                            && request.resource.data.type is string
                            && request.resource.data.date is string
                            && request.resource.data.registrationId is string
                            && request.resource.data.registrationName is string
                            && request.resource.data.tanzeem is string
                            && request.resource.data.majlis is string
                            && request.resource.data.idNumber is string
                            && request.resource.data.timestamp is string
                            && (!('registrationResponse' in request.resource.data)
                                || request.resource.data.registrationResponse in ['accept', 'decline'])
                            && (!('declineReason' in request.resource.data)
                                || request.resource.data.declineReason == null
                                || request.resource.data.declineReason is string);

      // allow internal + external cleanup delete
      allow delete: if isRegistrationEntriesCollection(collection);
    }

    // attendance_qr_device_registrations (global)
    match /attendance_qr_device_registrations/{deviceId} {
      allow read: if true;
      allow create, update: if isAllowedQrRegistrationDoc(deviceId);
      // allow delete for reset workflows (internal + external)
      allow delete: if true;
    }

    // admin_accounts_global
    match /admin_accounts_global/{nameKey} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if true;
    }

    // admin_accounts_external
    match /admin_accounts_external/{nameKey} {
      allow read: if true;
      allow create, update: if request.resource.data.keys().hasOnly([
                              'name', 'nameKey', 'authEmail', 'authUid',
                              'localPassword', 'localPasswordHash',
                              'mosqueId', 'mosqueIds', 'preferredMosqueId',
                              'permissions', 'isExternalGuest',
                              'externalMultipleMajalis', 'externalShowNames', 'externalMosqueName',
                              'accountCollection',
                              'isSuperAdmin', 'active', 'createdAt', 'createdBy', 'updatedAt'
                            ])
                            && request.resource.data.nameKey == nameKey;
      allow delete: if true;
    }

    // external_guest_configs
    match /external_guest_configs/{docId} {
      allow read: if true;
      allow create, update: if request.resource.data.keys().hasOnly([
                              'accountNameKey', 'mosqueName', 'scopeKey',
                              'multipleMajalis', 'showNames', 'updatedAt'
                            ])
                            && request.resource.data.accountNameKey is string
                            && request.resource.data.scopeKey is string
                            && request.resource.data.mosqueName is string
                            && (
                              request.resource.data.accountNameKey == docId
                              || request.resource.data.scopeKey == docId
                            );
      allow delete: if true;
    }

    // fallback deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
